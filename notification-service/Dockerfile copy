FROM node:20-alpine AS builder
WORKDIR /app
RUN apk add --no-cache bash python3 make g++ pkgconfig librdkafka-dev

COPY kafka-rdkafka-1.0.0.tgz ./
COPY notification-service/package*.json ./notification-service/
RUN cd notification-service && npm install

COPY notification-service ./notification-service
RUN cd notification-service && npm run build

FROM node:20-alpine
WORKDIR /app
RUN apk add --no-cache bash python3 make g++ pkgconfig librdkafka-dev

COPY kafka-rdkafka-1.0.0.tgz ./
COPY notification-service/package*.json ./notification-service/
RUN cd notification-service && npm install --omit=dev

COPY --from=builder /app/notification-service/dist ./notification-service/dist
EXPOSE 3005
CMD ["node", "notification-service/dist/main"]
